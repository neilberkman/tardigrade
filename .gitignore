# Python caches
__pycache__/
*.pyc

# Build artifacts
*.elf
*.o
*.bin

# Keep prebuilt examples for out-of-the-box runnable OSS usage.
!examples/vulnerable_ota/*.elf
!examples/vulnerable_ota/*.bin
!examples/resilient_ota/*.elf
!examples/resilient_ota/*.bin
!examples/test_image.bin
!examples/fault_variants/*.elf
!examples/fault_variants/*.bin
!examples/naive_copy/*.elf
!examples/naive_copy/*.bin
!examples/nxboot_style/*.elf
!examples/nxboot_style/*.bin
!examples/riotboot_standalone/*.elf
!examples/riotboot_standalone/*.bin
!examples/esp_idf_ota/*.elf
!examples/esp_idf_ota/*.bin
!results/oss_validation/assets/*.elf
!results/oss_validation/assets/*.bin

# Robot outputs
output.xml
robot_output.xml
log.html
report.html
results-*.xml
logs/
snapshots/

# Campaign scratch outputs
results/full_campaign.json
results/resilient_campaign.json
results/resilient_meta_campaign.json
results/vulnerable_campaign.json

# Audit run artifacts and result JSONs (generated, not committed)
results/audit_runs/
results/*.json

# Build outputs
results/oss_validation/build/

# Third-party source checkouts
third_party/

# CBMC generated outputs (keep harness/source, ignore solver result dumps)
examples/resilient_ota/cbmc/cbmc_*.json
examples/resilient_ota/cbmc/*_output.json
